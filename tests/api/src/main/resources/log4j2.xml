<Configuration>
    <Properties>
        <Property name="layout">%d [%t] %-5level %logger - %min</Property>
    </Properties>
    <Appenders>
        <Console name="Console" target="SYSTEM_OUT">
            <PatternLayout pattern="${layout}"/>
        </Console>
        <File name="BookFile" fileName="src/main/resources/logs/book.log" append="false">
            <PatternLayout>
                <Pattern>%d %p %c{1.} %m%n</Pattern>
            </PatternLayout>
        </File>
    </Appenders>
    <Loggers>
        <Logger name="bookLogger" level="info" additivity="false">
            <AppenderRef ref="BookFile" />
        </Logger>
        <Root level="error">
            <AppenderRef ref="Console"/>
        </Root>
    </Loggers>
</Configuration>
